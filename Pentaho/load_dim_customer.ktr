  <step>
    <name>stg_customer</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>ICE_Entertainment</connection>
    <sql>SELECT
    c.customer_number,
    c.name,
    c.gender,
    STR_TO_DATE(c.date_of_birth, '%Y-%m-%d')        AS date_of_birth,
    CASE
        WHEN TIMESTAMPDIFF(YEAR, STR_TO_DATE(c.date_of_birth, '%Y-%m-%d'), CURDATE()) &lt;= 30
            THEN '30 and under'
        WHEN TIMESTAMPDIFF(YEAR, STR_TO_DATE(c.date_of_birth, '%Y-%m-%d'), CURDATE()) &lt;= 50
            THEN '31 to 50'
        ELSE 'Over 50'
    END                                              AS age_group,
    c.city,
    c.state,
    c.zipcode,
    c.country,
    c.market,
    c.customer_type,
    c.status,
    c.occupation,
    hhi.description                                  AS household_income,
    c.permission,
    c.preferred_channel1,
    c.preferred_channel2,
    c.interest1,
    c.interest2,
    c.interest3,
    STR_TO_DATE(c.date_registered, '%Y-%m-%d')       AS effective_date,
    NULL                                             AS expiry_date,
    1                                                AS is_current
FROM stg.stg_customer c
LEFT JOIN stg.stg_house_hold_income hhi
    ON c.household_income = hhi.household_income_code</sql>
    <limit>0</limit>
    <lookup/>
    <execute_each_row>N</execute_each_row>
    <variables_active>N</variables_active>
