  <step>
    <name>subscription_package_query</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>ICE_Entertainment</connection>
    <sql>Select 
       dd.date_key,
       dc.customer_key,
       dp.package_key,
       dc.preferred_channel1                     AS channel,
       DATEDIFF(IFNULL(dp.package_subscription_end_date , CURRENT_DATE), 
       dp.package_subscription_start_date)          AS subscription_duration_days,
	   
       dp.subscription_status,
       
	CASE
        WHEN dp.subscription_status = 'Active' THEN 1
        ELSE 0
    END                                          AS active_flag,
    CASE
        WHEN dp.subscription_status = 'Cancelled' THEN 1
        ELSE 0
    END                                         AS cancelled_flag,
    CASE
        WHEN dp.subscription_status = 'Expired' THEN 1
        ELSE 0
    END                                         AS expired_flag

FROM dw.dim_package dp
JOIN dw.dim_customer dc 
    ON dc.customer_number = dp.subscription_customer
    AND dc.is_current = 1
JOIN dw.dim_date  dd
   ON dp.package_subscription_start_date = dd.sql_date</sql>
    <limit>0</limit>
    <lookup/>
    <execute_each_row>N</execute_each_row>
    <variables_active>N</variables_active>
    <lazy_conversion_active>N</lazy_conversion_active>
