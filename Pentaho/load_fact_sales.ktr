  <step>
    <name>fact_sales_query</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>ICE_Entertainment</connection>
    <sql>SELECT
    -- Date key lookup
    dd.date_key,

    -- Customer key lookup (current record only)
    dc.customer_key,

    -- Product key lookup
    dp.product_key,

    -- Store key lookup
    ds.store_key,

    -- Currency key + rate lookup
    -- Most recent rate on or before order date
    cur.currency_key,

    -- Subscription key (nullable)
    dsub.subscription_key,

    -- Degenerate dimensions
    od.order_id,
    od.line_no,

    -- Raw measures
    od.qty,
    od.price,
    od.unit_cost,

    -- Exchange rate applied
    cur.currency_rate                                       AS exchange_rate,

    -- Calculated measures in USD
    ROUND(od.qty * od.price     * cur.currency_rate, 2)    AS dollar_sales_usd,
    ROUND(od.qty * od.unit_cost * cur.currency_rate, 2)    AS cost_usd,
    ROUND(
        (od.qty * od.price     * cur.currency_rate) -
        (od.qty * od.unit_cost * cur.currency_rate), 2
    )                                                       AS margin_usd

FROM stg.stg_order_details od

-- Join order header
JOIN stg.stg_order_header oh
    ON od.order_id = oh.order_id

-- Lookup date_key
JOIN dw.dim_date dd
    ON dd.sql_date = STR_TO_DATE(oh.order_date, '%Y-%m-%d')

-- Lookup customer_key
JOIN dw.dim_customer dc
    ON dc.customer_number = oh.customer_number
    AND dc.is_current = 1

-- Lookup product_key
JOIN dw.dim_product dp
    ON dp.product_code = od.product_code

-- Lookup store_key
JOIN dw.dim_store ds
    ON ds.store_number = oh.store_number

-- Lookup currency_key + rate
-- For USD orders, rate = 1.0 (USD rows we inserted manually)
JOIN dw.dim_currency cur
    ON cur.currency_code = oh.currency
    AND cur.effective_date = (
        SELECT MAX(cr2.effective_date)
        FROM dw.dim_currency cr2
        WHERE cr2.currency_code = oh.currency
          AND cr2.effective_date &lt;= STR_TO_DATE(oh.order_date, '%Y-%m-%d')
    )

-- Subscription key (nullable)
LEFT JOIN dw.dim_subscription dsub
    ON dsub.customer_number = oh.customer_number
    AND STR_TO_DATE(oh.order_date, '%Y-%m-%d')
        BETWEEN dsub.start_date
        AND COALESCE(dsub.end_date, '9999-12-31')</sql>
    <limit>0</limit>
